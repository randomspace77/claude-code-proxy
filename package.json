{
  "name": "claude-code-proxy-cf-workers",
  "version": "1.0.0",
  "type": "module",
  "description": "A Cloudflare Workers proxy that enables Claude Code to work with OpenAI-compatible API providers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "keywords": [
    "claude",
    "openai",
    "proxy",
    "cloudflare-workers",
    "api"
  ],
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@cloudflare/workers-types": "^4.20260410.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
