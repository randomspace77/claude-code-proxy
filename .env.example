# ============================================================
# Cloudflare Workers environment variables
# Copy this file to .dev.vars for local development
# Use `wrangler secret put <KEY>` for production secrets
# ============================================================

# ---- API Key 模式 ----
# 透传模式（推荐）：不设置 OPENAI_API_KEY，客户端的 key 直接转发给后端
# 托管模式：设置 OPENAI_API_KEY，所有请求使用服务端 key
# OPENAI_API_KEY="sk-your-openai-api-key-here"

# Optional: 客户端 key 验证（可选的额外安全层）
# 如果设置，客户端必须提供与此完全匹配的 API key 才能访问代理
# ANTHROPIC_API_KEY="your-expected-anthropic-api-key"

# Optional: OpenAI API base URL (default: https://api.openai.com/v1)
OPENAI_BASE_URL="https://api.openai.com/v1"

# Optional: Passthrough models
# 逗号分隔的模型前缀，匹配的模型以 Anthropic 格式直接转发（不做 OpenAI 转换）
# 例如：MiniMax 模型使用 Anthropic API 格式
# PASSTHROUGH_MODELS="minimax"

# Optional: Model mapping (default: disabled)
# When "true", maps Claude model names (opus/sonnet/haiku) to BIG/MIDDLE/SMALL_MODEL
# When "false" or unset, forwards the client's model-id as-is
# ENABLE_MODEL_MAPPING="true"

# Optional: Model mappings (only used when ENABLE_MODEL_MAPPING="true")
BIG_MODEL="gpt-4o"            # Used for Claude opus requests
MIDDLE_MODEL="gpt-4o"         # Used for Claude sonnet requests
SMALL_MODEL="gpt-4o-mini"     # Used for Claude haiku requests

# Optional: Performance settings
MAX_TOKENS_LIMIT="16384"
MIN_TOKENS_LIMIT="4096"
REQUEST_TIMEOUT="90"
LOG_LEVEL="WARNING"

# Optional: Azure OpenAI (set as secret if needed)
# AZURE_API_VERSION="2024-03-01-preview"

# Optional: Custom headers as a JSON string (set as secret if it contains tokens)
# CUSTOM_HEADERS='{"X-Custom-Header":"value","Authorization":"Bearer token"}'

# ============================================================
# Provider Examples
# ============================================================

# OpenCode Go（GLM + MiniMax 混合，透传模式）:
# OPENAI_BASE_URL="https://opencode.ai/zen/go/v1"
# PASSTHROUGH_MODELS="minimax"
# （不设置 OPENAI_API_KEY，客户端直接提供 key）
# GLM 模型走 OpenAI 转换，MiniMax 模型走 Anthropic 直转

# Azure OpenAI（托管模式）:
# OPENAI_API_KEY="your-azure-api-key"
# OPENAI_BASE_URL="https://your-resource.openai.azure.com/openai/deployments/your-deployment"
# AZURE_API_VERSION="2024-03-01-preview"
# BIG_MODEL="gpt-4"
# MIDDLE_MODEL="gpt-4"
# SMALL_MODEL="gpt-35-turbo"

# DeepSeek（托管模式）:
# OPENAI_API_KEY="your-deepseek-key"
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
# BIG_MODEL="deepseek-chat"
# SMALL_MODEL="deepseek-chat"
